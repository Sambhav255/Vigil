# Vigil — Environment Variables
# All variables are optional. The app renders with mock/seed data when keys are absent.
# Copy this file to .env.local and fill in the values you want to enable.

# ── Market Data ──────────────────────────────────────────────────────────────
# Live stock quotes (SPY, QQQ, TSLA, NVDA, etc.)
ALPHA_VANTAGE_API_KEY=

# Live crypto prices (BTC, ETH). Falls back to Coinpaprika (free, no key).
COINGECKO_DEMO_API_KEY=

# Live macro indicators: CPI, unemployment, yield curve (FRED is free)
FRED_API_KEY=

# ── AI Analysis ──────────────────────────────────────────────────────────────
# Enables /api/analyze deep-dive — https://console.groq.com/keys
GROQ_API_KEY=
# Optional override (see app default in app/api/analyze/route.ts)
# GROQ_MODEL=

# Your deployed URL — used for OG / Twitter meta tags (e.g. https://vigil.vercel.app)
NEXT_PUBLIC_SITE_URL=

# ── Auth (Convex — optional) ─────────────────────────────────────────────────
# Required only if you want user accounts and persistent watchlists.
# Run `npx convex dev` in vigil-app/ to provision a project; it will set these.
NEXT_PUBLIC_CONVEX_URL=
